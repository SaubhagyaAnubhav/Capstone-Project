  "cells": [
    {
      "cell_type": "markdown",
      "source": "# Final Load Preparation\n\nThis notebook prepares the final dataset for Tableau visualization and creates optimized data exports for dashboard creation.",
      "metadata": {}
    },
    {
      "cell_type": "markdown",
      "source": "## Prerequisites\n\nRun this notebook in a Python 3 environment with the following packages:\n\n```bash\npip install -r ../requirements.txt\n```\n\nOr install individually:\n```bash\npip install pandas numpy matplotlib seaborn\n```",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "import numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom datetime import datetime\nimport warnings\nwarnings.filterwarnings('ignore')\n\nprint(\"Final Load Preparation Started...\")\nprint(f\"Timestamp: {datetime.now()}\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": "# Load the master dataset\ndf = pd.read_csv('../data/processed/master_dataset.csv')\n\nprint(f\"Original Dataset Shape: {df.shape}\")\nprint(f\"Memory Usage: {df.memory_usage(deep=True).sum() / 1024**2:.2f} MB\")\nprint(f\"Columns: {len(df.columns)}\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "source": "## 1. Data Quality Assessment",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "# Final data quality check\nprint(\"FINAL DATA QUALITY ASSESSMENT:\")\nprint(\"=\" * 50)\n\n# Missing values\nmissing_summary = df.isnull().sum()\nmissing_pct = (missing_summary / len(df)) * 100\n\nprint(\"\\nMISSING VALUES SUMMARY:\")\nfor col in missing_summary[missing_summary > 0].index:\n    print(f\"  {col}: {missing_summary[col]:,} ({missing_pct[col]:.1f}%)\")\n\n# Data types\nprint(f\"\\nDATA TYPES:\")\nprint(df.dtypes.value_counts())\n\n# Duplicates\nduplicates = df.duplicated().sum()\nprint(f\"\\nDUPLICATE ROWS: {duplicates:,}\")\n\n# Unique values in key columns\nkey_cols = ['order_id', 'customer_id', 'product_id']\nprint(f\"\\nUNIQUE VALUES:\")\nfor col in key_cols:\n    if col in df.columns:\n        unique_count = df[col].nunique()\n        total_count = len(df)\n        print(f\"  {col}: {unique_count:,} unique out of {total_count:,} total\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "source": "## 2. Create Optimized Datasets for Tableau",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "# Convert date columns to proper datetime format\ndate_columns = ['order_purchase_timestamp', 'order_approved_at', \n               'order_delivered_carrier_date', 'order_delivered_customer_date',\n               'order_estimated_delivery_date', 'review_creation_date', \n               'review_answer_timestamp', 'shipping_limit_date']\n\nfor col in date_columns:\n    if col in df.columns:\n        df[col] = pd.to_datetime(df[col], errors='coerce')\n        print(f\"Converted {col} to datetime\")\n\n# Create additional time-based features for Tableau\nif 'order_purchase_timestamp' in df.columns:\n    df['order_year'] = df['order_purchase_timestamp'].dt.year\n    df['order_month'] = df['order_purchase_timestamp'].dt.month\n    df['order_quarter'] = df['order_purchase_timestamp'].dt.quarter\n    df['order_day_of_week'] = df['order_purchase_timestamp'].dt.day_name()\n    df['order_hour'] = df['order_purchase_timestamp'].dt.hour\n    df['order_date'] = df['order_purchase_timestamp'].dt.date\n    \n    print(\"Created time-based features for analysis\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": "# Create business metrics for dashboard\nprint(\"\\nCREATING BUSINESS METRICS:\")\n\n# Revenue metrics\nif 'payment_value' in df.columns:\n    df['revenue_category'] = pd.cut(df['payment_value'], \n                                   bins=[0, 50, 100, 200, 500, float('inf')],\n                                   labels=['Low (0-50)', 'Medium (50-100)', \n                                          'High (100-200)', 'Premium (200-500)', \n                                          'Luxury (500+)'])\n    print(\"Created revenue categories\")\n\n# Customer satisfaction categories\nif 'review_score' in df.columns:\n    df['satisfaction_level'] = df['review_score'].map({\n        1: 'Very Dissatisfied',\n        2: 'Dissatisfied', \n        3: 'Neutral',\n        4: 'Satisfied',\n        5: 'Very Satisfied'\n    })\n    print(\"Created satisfaction level categories\")\n\n# Delivery performance\nif 'delivery_time_days' in df.columns:\n    df['delivery_performance'] = pd.cut(df['delivery_time_days'],\n                                       bins=[0, 7, 14, 21, 30, float('inf')],\n                                       labels=['Excellent (≤7 days)', 'Good (8-14 days)',\n                                              'Average (15-21 days)', 'Poor (22-30 days)',\n                                              'Very Poor (>30 days)'])\n    print(\"Created delivery performance categories\")\n\n# Product price categories\nif 'price' in df.columns:\n    df['price_segment'] = pd.qcut(df['price'], q=4, \n                                 labels=['Budget', 'Economy', 'Mid-Range', 'Premium'])\n    print(\"Created price segments\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "source": "## 3. Create Aggregated Datasets",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "# 1. Monthly Summary Dataset\nprint(\"\\nCREATING MONTHLY SUMMARY DATASET:\")\n\nif 'order_purchase_timestamp' in df.columns:\n    monthly_summary = df.groupby(df['order_purchase_timestamp'].dt.to_period('M')).agg({\n        'order_id': 'count',\n        'payment_value': ['sum', 'mean'],\n        'review_score': 'mean',\n        'delivery_time_days': 'mean',\n        'customer_unique_id': 'nunique',\n        'product_id': 'nunique'\n    }).round(2)\n    \n    monthly_summary.columns = ['Total_Orders', 'Total_Revenue', 'Avg_Order_Value', \n                              'Avg_Review_Score', 'Avg_Delivery_Days', \n                              'Unique_Customers', 'Unique_Products']\n    \n    monthly_summary.reset_index(inplace=True)\n    monthly_summary['Year_Month'] = monthly_summary['order_purchase_timestamp'].astype(str)\n    \n    print(f\"Monthly summary created: {monthly_summary.shape}\")\n    display(monthly_summary.head())"
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": "# 2. State Performance Dataset\nprint(\"\\nCREATING STATE PERFORMANCE DATASET:\")\n\nif 'customer_state' in df.columns:\n    state_performance = df.groupby('customer_state').agg({\n        'order_id': 'count',\n        'payment_value': ['sum', 'mean'],\n        'review_score': 'mean',\n        'delivery_time_days': 'mean',\n        'customer_unique_id': 'nunique',\n        'is_negative_review': 'mean'\n    }).round(2)\n    \n    state_performance.columns = ['Total_Orders', 'Total_Revenue', 'Avg_Order_Value',\n                                'Avg_Review_Score', 'Avg_Delivery_Days', \n                                'Unique_Customers', 'Negative_Review_Rate']\n    \n    state_performance.reset_index(inplace=True)\n    state_performance = state_performance.sort_values('Total_Orders', ascending=False)\n    \n    print(f\"State performance created: {state_performance.shape}\")\n    display(state_performance.head(10))"
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": "# 3. Product Category Analysis Dataset\nprint(\"\\nCREATING PRODUCT CATEGORY DATASET:\")\n\nif 'product_category_name_english' in df.columns:\n    category_analysis = df.groupby('product_category_name_english').agg({\n        'order_id': 'count',\n        'price': 'mean',\n        'payment_value': 'sum',\n        'review_score': 'mean',\n        'freight_value': 'mean',\n        'product_weight_g': 'mean',\n        'is_negative_review': 'mean'\n    }).round(2)\n    \n    category_analysis.columns = ['Order_Count', 'Avg_Price', 'Total_Revenue',\n                                'Avg_Review_Score', 'Avg_Freight_Cost', \n                                'Avg_Weight', 'Negative_Review_Rate']\n    \n    category_analysis.reset_index(inplace=True)\n    category_analysis = category_analysis.sort_values('Order_Count', ascending=False)\n    \n    print(f\"Category analysis created: {category_analysis.shape}\")\n    display(category_analysis.head(10))"
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": "# 4. Customer Segmentation Dataset\nprint(\"\\nCREATING CUSTOMER SEGMENTATION DATASET:\")\n\nif 'customer_unique_id' in df.columns:\n    customer_segments = df.groupby('customer_unique_id').agg({\n        'order_id': 'count',\n        'payment_value': ['sum', 'mean'],\n        'review_score': 'mean',\n        'delivery_time_days': 'mean',\n        'order_purchase_timestamp': ['min', 'max']\n    }).round(2)\n    \n    customer_segments.columns = ['Total_Orders', 'Total_Spent', 'Avg_Order_Value',\n                                'Avg_Review_Score', 'Avg_Delivery_Days',\n                                'First_Order_Date', 'Last_Order_Date']\n    \n    # Calculate customer lifetime (days between first and last order)\n    customer_segments['Customer_Lifetime_Days'] = (\n        customer_segments['Last_Order_Date'] - customer_segments['First_Order_Date']\n    ).dt.days\n    \n    # Create customer segments\n    customer_segments['Customer_Segment'] = pd.cut(\n        customer_segments['Total_Orders'],\n        bins=[0, 1, 2, 5, float('inf')],\n        labels=['One-time', 'Occasional', 'Regular', 'Loyal']\n    )\n    \n    customer_segments.reset_index(inplace=True)\n    \n    print(f\"Customer segmentation created: {customer_segments.shape}\")\n    print(\"\\nCustomer Segment Distribution:\")\n    print(customer_segments['Customer_Segment'].value_counts())"
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "source": "## 4. Data Optimization for Tableau",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "# Optimize main dataset for Tableau\nprint(\"\\nOPTIMIZING DATASET FOR TABLEAU:\")\n\n# Select key columns for main dashboard\ntableau_columns = [\n    # Order information\n    'order_id', 'order_status', 'order_purchase_timestamp', 'order_year', \n    'order_month', 'order_quarter', 'order_day_of_week', 'order_date',\n    \n    # Customer information\n    'customer_id', 'customer_unique_id', 'customer_state', 'customer_city',\n    \n    # Product information\n    'product_id', 'product_category_name', 'product_category_name_english',\n    'price', 'price_segment',\n    \n    # Payment information\n    'payment_type', 'payment_value', 'payment_installments', 'revenue_category',\n    \n    # Review information\n    'review_score', 'satisfaction_level', 'sentiment', 'is_negative_review',\n    \n    # Delivery information\n    'delivery_time_days', 'delivery_performance', 'is_delivered_clean',\n    \n    # Additional metrics\n    'freight_value', 'item_total_value'\n]\n\n# Filter columns that exist in the dataset\ntableau_columns = [col for col in tableau_columns if col in df.columns]\n\n# Create optimized dataset\ndf_tableau = df[tableau_columns].copy()\n\nprint(f\"Optimized dataset shape: {df_tableau.shape}\")\nprint(f\"Columns reduced from {len(df.columns)} to {len(df_tableau.columns)}\")\nprint(f\"Memory usage: {df_tableau.memory_usage(deep=True).sum() / 1024**2:.2f} MB\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "source": "## 5. Export Datasets",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "# Create output directory structure\nimport os\n\noutput_dirs = ['../tableau', '../reports']\nfor directory in output_dirs:\n    if not os.path.exists(directory):\n        os.makedirs(directory)\n        print(f\"Created directory: {directory}\")\n\nprint(\"\\nEXPORTING DATASETS:\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": "# Export main Tableau dataset\ndf_tableau.to_csv('../tableau/main_dashboard_data.csv', index=False)\nprint(f\"Exported main dashboard data: {df_tableau.shape}\")\n\n# Export aggregated datasets\nif 'monthly_summary' in locals():\n    monthly_summary.to_csv('../tableau/monthly_trends.csv', index=False)\n    print(f\"Exported monthly trends: {monthly_summary.shape}\")\n\nif 'state_performance' in locals():\n    state_performance.to_csv('../tableau/state_performance.csv', index=False)\n    print(f\"Exported state performance: {state_performance.shape}\")\n\nif 'category_analysis' in locals():\n    category_analysis.to_csv('../tableau/category_analysis.csv', index=False)\n    print(f\"Exported category analysis: {category_analysis.shape}\")\n\nif 'customer_segments' in locals():\n    customer_segments.to_csv('../tableau/customer_segments.csv', index=False)\n    print(f\"Exported customer segments: {customer_segments.shape}\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": "# Create data dictionary for Tableau users\ndata_dictionary = {\n    'Column_Name': [],\n    'Description': [],\n    'Data_Type': [],\n    'Example_Values': []\n}\n\n# Define column descriptions\ncolumn_descriptions = {\n    'order_id': 'Unique identifier for each order',\n    'customer_id': 'Unique identifier for each customer per order',\n    'customer_unique_id': 'Unique identifier for each customer across all orders',\n    'order_status': 'Current status of the order',\n    'order_purchase_timestamp': 'Date and time when order was placed',\n    'customer_state': 'State where customer is located',\n    'customer_city': 'City where customer is located',\n    'product_category_name_english': 'Product category in English',\n    'price': 'Price of the product',\n    'payment_value': 'Total payment amount for the order',\n    'payment_type': 'Method of payment used',\n    'review_score': 'Customer review score (1-5)',\n    'delivery_time_days': 'Number of days for delivery',\n    'satisfaction_level': 'Customer satisfaction category based on review score',\n    'revenue_category': 'Revenue category based on payment value',\n    'delivery_performance': 'Delivery performance category based on delivery time'\n}\n\n# Build data dictionary\nfor col in df_tableau.columns:\n    data_dictionary['Column_Name'].append(col)\n    data_dictionary['Description'].append(column_descriptions.get(col, 'No description available'))\n    data_dictionary['Data_Type'].append(str(df_tableau[col].dtype))\n    \n    # Get example values\n    if df_tableau[col].dtype == 'object':\n        examples = df_tableau[col].dropna().unique()[:3]\n        data_dictionary['Example_Values'].append(', '.join(map(str, examples)))\n    else:\n        examples = df_tableau[col].dropna().head(3).values\n        data_dictionary['Example_Values'].append(', '.join(map(str, examples)))\n\ndata_dict_df = pd.DataFrame(data_dictionary)\ndata_dict_df.to_csv('../tableau/data_dictionary.csv', index=False)\nprint(f\"Exported data dictionary: {data_dict_df.shape}\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "markdown",
      "source": "## 6. Final Validation and Summary",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "# Final validation\nprint(\"\\nFINAL VALIDATION:\")\nprint(\"=\" * 50)\n\n# Check for any remaining data quality issues\nprint(\"\\nDATA QUALITY CHECK:\")\nfor dataset_name, dataset in [('Main Dashboard', df_tableau)]:\n    if dataset is not None:\n        missing_pct = (dataset.isnull().sum() / len(dataset) * 100).max()\n        duplicates = dataset.duplicated().sum()\n        \n        print(f\"\\n{dataset_name}:\")\n        print(f\"  • Shape: {dataset.shape}\")\n        print(f\"  • Max missing %: {missing_pct:.1f}%\")\n        print(f\"  • Duplicates: {duplicates:,}\")\n        print(f\"  • Memory: {dataset.memory_usage(deep=True).sum() / 1024**2:.1f} MB\")\n\n# Summary of exported files\nprint(\"\\nEXPORTED FILES SUMMARY:\")\nexported_files = [\n    'main_dashboard_data.csv',\n    'monthly_trends.csv', \n    'state_performance.csv',\n    'category_analysis.csv',\n    'customer_segments.csv',\n    'data_dictionary.csv'\n]\n\nfor file in exported_files:\n    file_path = f'../tableau/{file}'\n    if os.path.exists(file_path):\n        file_size = os.path.getsize(file_path) / 1024**2\n        print(f\"  {file} ({file_size:.1f} MB)\")\n    else:\n        print(f\"  {file} (not found)\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [],
      "execution_count": null
    },
    {
      "cell_type": "code",
      "source": "# Create final summary report\nprint(\"\\n\" + \"=\" * 70)\nprint(\"FINAL LOAD PREPARATION SUMMARY\")\nprint(\"=\" * 70)\n\nprint(f\"\\nPREPARATION COMPLETED SUCCESSFULLY!\")\nprint(f\"\\nDATASETS READY FOR TABLEAU:\")\nprint(f\"   • Main Dashboard Data: {df_tableau.shape[0]:,} rows, {df_tableau.shape[1]} columns\")\nprint(f\"   • Monthly Trends: Time-series analysis ready\")\nprint(f\"   • State Performance: Geographic analysis ready\")\nprint(f\"   • Category Analysis: Product insights ready\")\nprint(f\"   • Customer Segments: Customer behavior analysis ready\")\n\nprint(f\"\\nOPTIMIZATIONS APPLIED:\")\nprint(f\"   • Date columns properly formatted\")\nprint(f\"   • Business metrics created\")\nprint(f\"   • Categorical variables optimized\")\nprint(f\"   • Memory usage optimized\")\n\nprint(f\"\\nTABLEAU DASHBOARD RECOMMENDATIONS:\")\nprint(f\"   • Executive Summary Dashboard\")\nprint(f\"   • Sales Performance Analysis\")\nprint(f\"   • Customer Satisfaction Monitoring\")\nprint(f\"   • Geographic Performance Analysis\")\nprint(f\"   • Product Category Deep Dive\")\nprint(f\"   • Customer Segmentation Analysis\")\n\nprint(f\"\\nFILES LOCATION: ../tableau/\")\nprint(f\"\\nReady for Tableau visualization!\")\n\nprint(\"\\n\" + \"=\" * 70)\nprint(f\"PROCESS COMPLETED: {datetime.now()}\")\nprint(\"=\" * 70)",
      "metadata": {
